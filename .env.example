# ==========================================
# LinkPulse v2 - Production Environment File
# ==========================================

# ── Supabase ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Telegram ───────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh

# ── Server ────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Application ───────────────────────────
APP_URL=https://linkpulse.railway.app

# ── Monitor Configuration ──────────────────
# Check interval (cron expression)
CHECK_INTERVAL=*/5 * * * *

# HTTP timeout per request (milliseconds)
TIMEOUT_MS=10000

# Alert threshold for high latency (milliseconds)
LATENCY_ALERT_MS=3000

# Global timeout for entire check cycle (milliseconds)
# Si un ciclo tarda más de esto, se cancela
CHECK_TIMEOUT_MS=60000
